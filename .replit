modules = ["nodejs-20", "web", "bash", "postgresql-16"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 20646
externalPort = 3000

[[ports]]
localPort = 21672
externalPort = 3001

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 180000

[userenv]

[userenv.shared]
AI_BASE_URL = "https://integrate.api.nvidia.com/v1"
AI_MODEL = "zhipuai/glm-4-9b"
