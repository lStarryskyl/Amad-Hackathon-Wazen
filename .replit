modules = ["nodejs-20", "web", "bash", "postgresql-16", "python-base-3.13"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/wazen-landing: web"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/api-server: API Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/finance-mobile: expo"

[[workflows.workflow]]
name = "artifacts/wazen-landing: web"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=20646 BASE_PATH=/ pnpm --filter @workspace/wazen-landing run dev"
waitForPort = 20646

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "artifacts/api-server: API Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=8080 pnpm --filter @workspace/api-server run dev"
waitForPort = 8080

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "artifacts/finance-mobile: expo"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=8081 pnpm --filter @workspace/finance-mobile run dev"
waitForPort = 8081

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 5000

[[ports]]
localPort = 9001
externalPort = 3002

[[ports]]
localPort = 9099
externalPort = 3003

[[ports]]
localPort = 20646
externalPort = 3000

[[ports]]
localPort = 21672
externalPort = 3001

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 180000

[userenv]

[userenv.shared]
AI_BASE_URL = "https://integrate.api.nvidia.com/v1"
AI_MODEL = "meta/llama-3.1-70b-instruct"
PORT = "8080"
