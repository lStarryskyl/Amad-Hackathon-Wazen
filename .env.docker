# Wazen Docker Environment Variables
# Copy this file to .env and fill in your actual values

# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────
POSTGRES_PASSWORD=wazen_secure_password_change_in_prod

# ─────────────────────────────────────────────
# Clerk Authentication (get from clerk.com)
# ─────────────────────────────────────────────
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# ─────────────────────────────────────────────
# AI Model (OpenAI-compatible)
# ─────────────────────────────────────────────
AI_API_KEY=sk-...
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini

# ─────────────────────────────────────────────
# API Domain (for mobile/landing to call API)
# Use your actual domain in production
# ─────────────────────────────────────────────
EXPO_PUBLIC_DOMAIN=http://localhost:8080