{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development && pnpm run build && pnpm run start",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:fallback": "node --experimental-strip-types src/lib/fallback-narratives.test.ts",
    "test:engagement": "pnpm run build && node --experimental-strip-types src/routes/engagement.test.ts",
    "test:simulations": "pnpm run build && node --experimental-strip-types src/routes/simulations.test.ts",
    "test:ai-parsing": "pnpm run build && /nix/store/bl6iwirn83qj9r8wng43kfdqd5mfahj8-nodejs-22.22.0/bin/node --experimental-strip-types src/lib/scenarioParsing.live-test.ts"
  },
  "dependencies": {
    "@clerk/express": "^2.1.35",
    "@clerk/shared": "^4.23.0",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "drizzle-orm": "catalog:",
    "expo-server-sdk": "^6.1.0",
    "express": "^5.2.1",
    "http-proxy-middleware": "^4.1.1",
    "openai": "^6.45.0",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "svix": "^1.96.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "esbuild": "0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13.1.3",
    "thread-stream": "3.1.0"
  }
}
